// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User Model
model User {
  id                    String                   @id @default(cuid())
  email                 String                   @unique
  password              String?
  name                  String
  avatar                String?
  bio                   String?
  role                  UserRole                 @default(MODERATOR)
  isActive              Boolean                  @default(true)
  
  // Relationships
  subreddits            SubredditModerator[]
  modLogs               ModLog[]
  actionsTaken          ModerationAction[]
  alerts                Alert[]
  communityHealthDashboard CommunityHealth[]
  aiInsights            AIInsight[]
  
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
}

enum UserRole {
  ADMIN
  MODERATOR
  ANALYST
  VIEWER
}

// Subreddit Model
model Subreddit {
  id                    String                   @id @default(cuid())
  name                  String                   @unique
  description           String?
  rules                 Rule[]
  members               Int                      @default(0)
  
  // Moderation Settings
  toxicityThreshold     Float                    @default(0.7)
  spamDetectionEnabled  Boolean                  @default(true)
  raidDetectionEnabled  Boolean                  @default(true)
  autoModerationLevel   ModerationLevel          @default(MODERATE)
  
  // Relationships
  moderators            SubredditModerator[]
  posts                 Post[]
  comments              Comment[]
  modLogs               ModLog[]
  alerts                Alert[]
  communityHealth       CommunityHealth?
  aiInsights            AIInsight[]
  
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
}

enum ModerationLevel {
  STRICT
  MODERATE
  LENIENT
  MANUAL_ONLY
}

// Subreddit Moderators Junction
model SubredditModerator {
  id                    String                   @id @default(cuid())
  userId                String
  subredditId           String
  permissions           ModeratorPermission[]
  
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subreddit             Subreddit                @relation(fields: [subredditId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime                 @default(now())
  
  @@unique([userId, subredditId])
}

enum ModeratorPermission {
  MANAGE_POSTS
  MANAGE_COMMENTS
  MANAGE_USERS
  MANAGE_RULES
  VIEW_ANALYTICS
  MANAGE_MODERATORS
  FULL_ACCESS
}

// Rule Model
model Rule {
  id                    String                   @id @default(cuid())
  subredditId           String
  title                 String
  description           String
  examples              String[]                 @default([])
  severity              Severity                 @default(MEDIUM)
  
  subreddit             Subreddit                @relation(fields: [subredditId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Post Model
model Post {
  id                    String                   @id @default(cuid())
  subredditId           String
  redditPostId          String?
  title                 String
  content               String?
  author                String
  score                 Int                      @default(0)
  
  // AI Analysis
  toxicityScore         Float?
  isSpam                Boolean                  @default(false)
  isRaidRelated         Boolean                  @default(false)
  sentiment             Sentiment?
  aiExplanation         String?
  
  // Status
  status                PostStatus               @default(APPROVED)
  moderationAction      ModerationAction?
  
  // Relationships
  comments              Comment[]
  modLogs               ModLog[]
  
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  
  @@index([subredditId])
  @@index([createdAt])
}

enum PostStatus {
  APPROVED
  FLAGGED
  REMOVED
  PENDING_REVIEW
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// Comment Model
model Comment {
  id                    String                   @id @default(cuid())
  postId                String
  subredditId           String
  redditCommentId       String?
  content               String
  author                String
  score                 Int                      @default(0)
  
  // AI Analysis
  toxicityScore         Float?
  isSpam                Boolean                  @default(false)
  sentiment             Sentiment?
  aiExplanation         String?
  
  // Status
  status                CommentStatus            @default(APPROVED)
  moderationAction      ModerationAction?
  
  // Relationships
  post                  Post                     @relation(fields: [postId], references: [id], onDelete: Cascade)
  subreddit             Subreddit                @relation(fields: [subredditId], references: [id], onDelete: Cascade)
  modLogs               ModLog[]
  
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  
  @@index([postId])
  @@index([subredditId])
  @@index([createdAt])
}

enum CommentStatus {
  APPROVED
  FLAGGED
  REMOVED
  PENDING_REVIEW
}

// Moderation Action Model
model ModerationAction {
  id                    String                   @id @default(cuid())
  userId                String
  subredditId           String
  postId                String?
  commentId             String?
  action                ModActionType
  reason                String
  duration              Int?                     // in days, for temporary bans
  
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post                  Post?                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment               Comment?                 @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime                 @default(now())
  
  @@index([subredditId])
  @@index([createdAt])
}

enum ModActionType {
  APPROVE
  REMOVE
  LOCK
  UNLOCK
  MUTE
  UNMUTE
  BAN
  UNBAN
  WARN
  FLAG_REVIEW
}

// Moderation Log Model
model ModLog {
  id                    String                   @id @default(cuid())
  userId                String
  subredditId           String
  postId                String?
  commentId             String?
  action                String
  details               String?
  
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subreddit             Subreddit                @relation(fields: [subredditId], references: [id], onDelete: Cascade)
  post                  Post?                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment               Comment?                 @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime                 @default(now())
  
  @@index([subredditId])
  @@index([userId])
  @@index([createdAt])
}

// Alert Model
model Alert {
  id                    String                   @id @default(cuid())
  userId                String
  subredditId           String
  type                  AlertType
  priority              AlertPriority
  title                 String
  description           String
  isResolved            Boolean                  @default(false)
  
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subreddit             Subreddit                @relation(fields: [subredditId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime                 @default(now())
  resolvedAt            DateTime?
  
  @@index([subredditId])
  @@index([userId])
  @@index([createdAt])
}

enum AlertType {
  RAID_DETECTED
  SPAM_SURGE
  TOXICITY_SPIKE
  MOD_ACTION_NEEDED
  RULE_VIOLATION
  BURNOUT_WARNING
  SYSTEM_ALERT
}

enum AlertPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Community Health Model
model CommunityHealth {
  id                    String                   @id @default(cuid())
  subredditId           String                   @unique
  userId                String
  
  // Health Metrics
  overallHealthScore    Float                    @default(100)
  toxicityTrend         Float                    @default(0) // -100 to 100
  spamLevel             Float                    @default(0)
  communityEngagement   Float                    @default(0)
  moderatorBurnout      Float                    @default(0)
  
  // Stats
  totalPosts            Int                      @default(0)
  totalComments         Int                      @default(0)
  removedContent        Int                      @default(0)
  bannedUsers           Int                      @default(0)
  
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subreddit             Subreddit                @relation(fields: [subredditId], references: [id], onDelete: SetNull)
  
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
}

// AI Insight Model
model AIInsight {
  id                    String                   @id @default(cuid())
  userId                String
  subredditId           String
  type                  InsightType
  title                 String
  description           String
  recommendation        String?
  confidence            Float                    @default(0)
  data                  String?                  // JSON data
  
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subreddit             Subreddit                @relation(fields: [subredditId], references: [id], onDelete: Cascade)
  
  createdAt             DateTime                 @default(now())
  
  @@index([subredditId])
  @@index([createdAt])
}

enum InsightType {
  PATTERN
  ANOMALY
  RECOMMENDATION
  TREND
  PREDICTION
  OPTIMIZATION
}
